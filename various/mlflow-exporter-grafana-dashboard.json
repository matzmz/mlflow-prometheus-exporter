          "legendFormat": "Last Baseline Age",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Last Baseline Age",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Total failed collect plus baseline rebuild cycles over the active dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "background"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(mlflow_exporter_collect_errors_total{job=~\"$job\", instance=~\"$instance\"}[$__range])) + sum(increase(mlflow_exporter_baseline_errors_total{job=~\"$job\", instance=~\"$instance\"}[$__range]))",
          "instant": true,
          "legendFormat": "Failures in Range",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Failures in Range",
      "type": "stat"
    },
