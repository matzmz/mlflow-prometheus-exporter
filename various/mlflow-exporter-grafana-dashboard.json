        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Uses Prometheus `up` to show whether the exporter target is currently scrapeable.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "background"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "min(up{job=~\"$job\", instance=~\"$instance\"})",
          "instant": true,
          "legendFormat": "Exporter Reachability",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Exporter Reachability",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Latest collection cycle outcome from the exporter itself.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "background"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "FAIL"
                },
                "1": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "min(mlflow_exporter_last_collect_success{job=~\"$job\", instance=~\"$instance\"})",
          "instant": true,
          "legendFormat": "Collect Healthy",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Collect Healthy",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Latest baseline rebuild outcome.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "background"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "FAIL"
                },
                "1": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "min(mlflow_exporter_last_baseline_success{job=~\"$job\", instance=~\"$instance\"})",
          "instant": true,
          "legendFormat": "Baseline Healthy",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Baseline Healthy",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Seconds elapsed since the last completed collect cycle. Tune thresholds if your poll interval differs from 30s.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "background"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "time() - max(mlflow_exporter_last_collect_timestamp_seconds{job=~\"$job\", instance=~\"$instance\"})",
          "instant": true,
          "legendFormat": "Last Collect Age",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Last Collect Age",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
